# Supabase — public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase — server only (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Google OAuth — Get from https://console.cloud.google.com/
# Steps: Create project → Create OAuth 2.0 credentials → Copy Client ID & Secret
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=your-client-secret

# Share invites & Email
# APP_BASE_URL is used for email links (must be production URL in production)
APP_BASE_URL=http://localhost:3000

SHARE_INVITE_TTL_HOURS=48

# Session timeout configuration (seconds)
NEXT_PUBLIC_SESSION_TIMEOUT_DURATION=1200
NEXT_PUBLIC_SESSION_TIMEOUT_WARNING=120

# Travel plan configuration
NEXT_PUBLIC_MAX_TRIP_DAYS=30

# Email — Resend (for invite emails and contact form)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key-here

SUPABASE_HOOK_SECRET=<the secret you generated>

NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_id.apps.googleusercontent.com
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your_id.apps.googleusercontent.com
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=your_secret
